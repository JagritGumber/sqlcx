async def list_users_by_date_range(conn: Connection, params: ListUsersByDateRangeParams) -> list[ListUsersByDateRangeRow]:
    rows = await conn.fetch(LIST_USERS_BY_DATE_RANGE_SQL, params.start_date, params.end_date)
