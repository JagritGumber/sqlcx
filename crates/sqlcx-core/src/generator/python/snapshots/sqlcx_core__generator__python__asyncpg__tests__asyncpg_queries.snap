from __future__ import annotations

from dataclasses import dataclass
from typing import Any
from datetime import datetime
from asyncpg import Connection


@dataclass
class GetUserRow:
    id: int
    name: str
    email: str
    bio: str | None
    status: str
    tags: list[str] | None
    created_at: datetime

@dataclass
class GetUserParams:
    id: int

GET_USER_SQL = "SELECT * FROM users WHERE id = $1"

async def get_user(conn: Connection, params: GetUserParams) -> GetUserRow | None:
    row = await conn.fetchrow(GET_USER_SQL, params.id)
    if row is None:
        return None
    return GetUserRow(**dict(row))


@dataclass
class ListUsersRow:
    id: int
    name: str
    email: str

@dataclass
class ListUsersParams:
    name: str

LIST_USERS_SQL = "SELECT id, name, email FROM users WHERE name ILIKE $1"

async def list_users(conn: Connection, params: ListUsersParams) -> list[ListUsersRow]:
    rows = await conn.fetch(LIST_USERS_SQL, params.name)
    return [ListUsersRow(**dict(row)) for row in rows]


@dataclass
class CreateUserParams:
    name: str
    email: str
    bio: str

CREATE_USER_SQL = "INSERT INTO users (name, email, bio) VALUES ($1, $2, $3)"

async def create_user(conn: Connection, params: CreateUserParams) -> None:
    await conn.execute(CREATE_USER_SQL, params.name, params.email, params.bio)


@dataclass
class DeleteUserParams:
    id: int

DELETE_USER_SQL = "DELETE FROM users WHERE id = $1"

async def delete_user(conn: Connection, params: DeleteUserParams) -> int:
    result = await conn.execute(DELETE_USER_SQL, params.id)
    return int(result.split()[-1])


