---
const sqlCode = `<span class="text-gray-500">-- schema.sql</span>
<span class="text-lime">CREATE TABLE</span> users (
  id <span class="text-accent-200">SERIAL PRIMARY KEY</span>,
  name <span class="text-accent-200">TEXT NOT NULL</span>,
  email <span class="text-accent-200">TEXT NOT NULL UNIQUE</span>,
  status <span class="text-accent-200">user_status NOT NULL DEFAULT</span> <span class="text-amber-300">'active'</span>
);

<span class="text-gray-500">-- queries/users.sql</span>
<span class="text-gray-500">-- name: GetUser :one</span>
<span class="text-lime">SELECT</span> * <span class="text-lime">FROM</span> users <span class="text-lime">WHERE</span> id = $1;`;

const tsCode = `<span class="text-lime">import</span> { Type, <span class="text-lime">type</span> Static } <span class="text-lime">from</span> <span class="text-amber-300">"@sinclair/typebox"</span>;

<span class="text-lime">export const</span> UsersSelect = Type.Object({
  id: Type.Number(),
  name: Type.String(),
  email: Type.String(),
  status: Type.Union([
    Type.Literal(<span class="text-amber-300">"active"</span>),
    Type.Literal(<span class="text-amber-300">"inactive"</span>),
    Type.Literal(<span class="text-amber-300">"banned"</span>),
  ]),
});

<span class="text-lime">export type</span> UsersSelect = Static&lt;<span class="text-lime">typeof</span> UsersSelect&gt;;`;
---

<section class="max-w-4xl mx-auto px-4 py-16 md:py-24">
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <div>
      <p class="text-xs uppercase tracking-widest text-gray-500 m-0 mb-2 font-mono">Write SQL</p>
      <div class="bg-gray-900 border border-gray-800 rounded-lg p-4 overflow-x-auto">
        <pre class="m-0 text-sm leading-relaxed"><code class="font-mono text-gray-300" set:html={sqlCode} /></pre>
      </div>
    </div>
    <div>
      <p class="text-xs uppercase tracking-widest text-gray-500 m-0 mb-2 font-mono">Get types</p>
      <div class="bg-gray-900 border border-gray-800 rounded-lg p-4 overflow-x-auto">
        <pre class="m-0 text-sm leading-relaxed"><code class="font-mono text-gray-300" set:html={tsCode} /></pre>
      </div>
    </div>
  </div>
</section>
