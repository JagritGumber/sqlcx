---

<section class="max-w-md mx-auto px-4 py-16 md:py-24 text-center">
  <h2 class="text-2xl font-bold text-white m-0 mb-8">Get started in seconds</h2>

  <!-- Install tabs -->
  <div class="mb-6">
    <div class="flex justify-center gap-1 mb-3" id="install-tabs">
      <button class="text-xs font-mono px-3 py-1 rounded-full bg-white/10 text-white border border-white/10 cursor-pointer" data-tab="npm" onclick="switchTab('npm')">npm</button>
      <button class="text-xs font-mono px-3 py-1 rounded-full bg-transparent text-gray-500 border border-transparent cursor-pointer" data-tab="cargo" onclick="switchTab('cargo')">cargo</button>
    </div>
    <div class="bg-gray-900 border border-gray-800 rounded-lg p-4 font-mono text-sm text-gray-300">
      <span class="text-gray-500 select-none">$ </span><span id="install-cmd">npm install sqlcx-orm</span>
    </div>
  </div>

  <!-- Generate command -->
  <div class="bg-gray-900 border border-gray-800 rounded-lg p-4 font-mono text-sm text-gray-300 mb-8">
    <span class="text-gray-500 select-none">$ </span>npx sqlcx generate
  </div>

  <a href="/getting-started/quick-start/" class="text-lime text-sm no-underline hover:underline">
    Read the Quick Start guide →
  </a>
</section>

<script>
  const commands = { npm: 'npm install sqlcx-orm', cargo: 'cargo install sqlcx' };
  function switchTab(tab) {
    document.getElementById('install-cmd').textContent = commands[tab];
    document.querySelectorAll('#install-tabs button').forEach(btn => {
      const isActive = btn.dataset.tab === tab;
      btn.className = `text-xs font-mono px-3 py-1 rounded-full cursor-pointer border ${
        isActive ? 'bg-white/10 text-white border-white/10' : 'bg-transparent text-gray-500 border-transparent'
      }`;
    });
  }
</script>
