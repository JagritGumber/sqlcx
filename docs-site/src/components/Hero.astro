---
---

<section class="flex flex-col items-center justify-center text-center px-4 py-16 md:py-0 md:min-h-screen gap-8">
  <!-- Logo lockup -->
  <div class="flex items-center gap-3 relative">
    <!-- Radial glow behind icon -->
    <div class="absolute -left-8 top-1/2 -translate-y-1/2 w-[120px] h-[120px] rounded-full bg-lime/10 blur-[60px] pointer-events-none"></div>
    <!-- Icon (the S) -->
    <div class="relative text-lime w-16 h-16 shrink-0">
      <svg width="64" height="64" viewBox="0 0 240 240" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M28 187.257C49.9979 198.68 83.4849 200.513 120.573 193.974C157.602 187.444 188.436 174.29 205.295 156.167L209.205 178.345C213.416 202.227 177.682 223.871 130.539 232.813L127.519 233.366C78.8889 241.941 36.2413 233.996 31.9401 209.602L28 187.257Z" fill="currentColor"/>
        <path d="M34.886 89C51.6501 107.258 82.4907 120.434 119.579 126.974C156.607 133.503 190.081 131.688 212.122 120.424L208.211 142.602C203.91 166.996 161.262 174.941 112.633 166.366C65.3816 158.034 28.7621 136.975 30.7967 113.401L30.8146 112.378L30.9459 111.345L34.886 89Z" fill="currentColor"/>
        <path d="M113.054 20.6077C123.306 18.8 133.302 17.728 142.716 17.3881L147.458 17.2729C153.135 17.2196 158.542 17.444 163.681 17.946L168.242 18.472L169.022 18.5781C171.857 18.9868 174.676 19.506 177.471 20.1347L179.58 20.6361C183.372 21.6055 186.853 22.7856 190.023 24.1764C191.234 24.7076 192.391 25.265 193.496 25.8487C196.294 27.3247 198.897 29.1444 201.245 31.2655L202.363 32.368C202.944 32.9763 203.49 33.5943 204 34.222L204.931 35.4693C206.406 37.5785 207.485 39.8591 208.168 42.3111L208.633 44.3717C212.934 68.7653 175.576 90.8176 126.946 99.3923C79.6948 107.724 38.0812 100.46 31.9301 77.6107C31.6747 76.9711 31.4861 76.3067 31.3673 75.6283L31.2359 74.5954L31.2199 73.5829C29.2344 50.5172 64.2284 29.8567 109.985 21.1692L113.054 20.6077Z" fill="currentColor"/>
      </svg>
    </div>
    <!-- QLCX text -->
    <span class="text-[3.5rem] leading-none font-bold text-white" style="font-family: var(--font-passion);">QLCX</span>
  </div>

  <!-- Tagline -->
  <h1 class="text-3xl md:text-[3.5rem] md:leading-tight font-bold text-white m-0">
    SQL-first. Every language. <span class="text-lime">Zero</span> runtime.
  </h1>

  <!-- Subtitle -->
  <p class="text-lg text-gray-400 m-0 max-w-xl">
    Write SQL once, generate type-safe code for TypeScript, Go, and Rust.
  </p>

  <!-- Stats pills -->
  <div class="flex items-center gap-3 flex-wrap justify-center">
    <span class="bg-white/5 border border-white/10 backdrop-blur-sm rounded-full px-4 py-1.5 text-sm text-gray-300">3 databases</span>
    <span class="bg-white/5 border border-white/10 backdrop-blur-sm rounded-full px-4 py-1.5 text-sm text-gray-300">3 languages</span>
    <span class="bg-white/5 border border-white/10 backdrop-blur-sm rounded-full px-4 py-1.5 text-sm text-gray-300">0 KB runtime</span>
  </div>

  <!-- CTAs -->
  <div class="flex gap-4 flex-wrap justify-center">
    <a href="/getting-started/quick-start/"
       class="bg-lime text-black font-semibold px-6 py-2.5 rounded-md no-underline text-sm hover:opacity-85 transition-opacity">
      Get Started
    </a>
    <a href="https://github.com/JagritGumber/sqlcx"
       target="_blank" rel="noopener"
       class="border border-lime text-lime font-semibold px-6 py-2.5 rounded-md no-underline text-sm hover:bg-lime/10 transition-colors">
      GitHub
    </a>
  </div>
</section>
