---
---

<section class="hero">
  <img src="/banner.png" alt="sqlcx" class="hero-banner" />

  <p class="hero-tagline">SQL-first. Every language. Zero runtime.</p>

  <p class="hero-subtitle">
    Write SQL once, generate type-safe code for TypeScript, Go, and Rust.
    No ORM. No bloat.
  </p>

  <div class="hero-stats">
    <span>3 databases</span>
    <span class="dot">·</span>
    <span>3 languages</span>
    <span class="dot">·</span>
    <span>0 KB runtime</span>
  </div>

  <div class="hero-actions">
    <a href="/getting-started/quick-start/" class="btn-primary">Get Started</a>
    <a href="https://github.com/JagritGumber/sqlcx" class="btn-outline" target="_blank" rel="noopener">GitHub</a>
  </div>
</section>

<style>
  .hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    max-width: 48rem;
    margin: 0 auto;
    padding: 4rem 1rem 2rem;
    gap: 1.25rem;
  }

  .hero-banner {
    max-width: 280px;
    width: 100%;
    height: auto;
  }

  .hero-tagline {
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--sl-color-accent);
    margin: 0;
    line-height: 1.2;
  }

  .hero-subtitle {
    font-size: 1.1rem;
    color: var(--sl-color-gray-3);
    margin: 0;
    max-width: 38rem;
    line-height: 1.6;
  }

  .hero-stats {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.95rem;
    color: var(--sl-color-gray-3);
  }

  .hero-stats .dot {
    color: var(--sl-color-gray-5);
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 0.5rem;
  }

  .btn-primary {
    background-color: var(--sl-color-accent);
    color: #000;
    font-weight: 600;
    padding: 0.6rem 1.4rem;
    border-radius: 0.375rem;
    text-decoration: none;
    font-size: 0.95rem;
    transition: opacity 0.15s ease;
  }

  .btn-primary:hover {
    opacity: 0.85;
  }

  .btn-outline {
    background-color: transparent;
    color: var(--sl-color-accent);
    border: 1.5px solid var(--sl-color-accent);
    font-weight: 600;
    padding: 0.6rem 1.4rem;
    border-radius: 0.375rem;
    text-decoration: none;
    font-size: 0.95rem;
    transition: background-color 0.15s ease;
  }

  .btn-outline:hover {
    background-color: color-mix(in srgb, var(--sl-color-accent) 10%, transparent);
  }
</style>
