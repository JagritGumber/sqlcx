---
const tsCode = `<span class="text-lime">export const</span> UsersSelect = Type.Object({
  id: Type.Number(),
  name: Type.String(),
  email: Type.String(),
  status: Type.Union([...]),
});`;

const goCode = `<span class="text-lime">type</span> UsersSelect <span class="text-lime">struct</span> {
  ID     int32  <span class="text-gray-500">\`db:"id" json:"id"\`</span>
  Name   string <span class="text-gray-500">\`db:"name" json:"name"\`</span>
  Email  string <span class="text-gray-500">\`db:"email" json:"email"\`</span>
  Status string <span class="text-gray-500">\`db:"status" json:"status"\`</span>
}`;

const rustCode = `<span class="text-gray-500">#[derive(Serialize, Deserialize)]</span>
<span class="text-lime">pub struct</span> UsersSelect {
    <span class="text-lime">pub</span> id: i32,
    <span class="text-lime">pub</span> name: String,
    <span class="text-lime">pub</span> email: String,
    <span class="text-lime">pub</span> status: String,
}`;
---

<section class="max-w-4xl mx-auto px-4 py-16 md:py-24">
  <h2 class="text-2xl font-bold text-white text-center m-0 mb-10">Every language. Same SQL.</h2>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
    <div class="bg-gray-900 border border-gray-800 rounded-lg p-4 overflow-x-auto">
      <span class="inline-block text-xs font-semibold bg-blue-500/15 text-blue-400 border border-blue-500/20 rounded-full px-3 py-0.5 mb-3">TypeScript</span>
      <pre class="m-0 text-xs leading-relaxed"><code class="font-mono text-gray-300" set:html={tsCode} /></pre>
    </div>

    <div class="bg-gray-900 border border-gray-800 rounded-lg p-4 overflow-x-auto">
      <span class="inline-block text-xs font-semibold bg-cyan-500/15 text-cyan-400 border border-cyan-500/20 rounded-full px-3 py-0.5 mb-3">Go</span>
      <pre class="m-0 text-xs leading-relaxed"><code class="font-mono text-gray-300" set:html={goCode} /></pre>
    </div>

    <div class="bg-gray-900 border border-gray-800 rounded-lg p-4 overflow-x-auto">
      <span class="inline-block text-xs font-semibold bg-orange-500/15 text-orange-400 border border-orange-500/20 rounded-full px-3 py-0.5 mb-3">Rust</span>
      <pre class="m-0 text-xs leading-relaxed"><code class="font-mono text-gray-300" set:html={rustCode} /></pre>
    </div>
  </div>
</section>
