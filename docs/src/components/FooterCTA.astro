<footer class="bg-surface-low py-12 px-8 mt-16">
  <div class="max-w-7xl mx-auto">
    <!-- Gradient divider -->
    <div class="bg-gradient-to-r from-transparent via-lime/10 to-transparent h-px mb-12"></div>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 mb-12">
      <!-- Brand -->
      <div class="col-span-2 md:col-span-1">
        <div class="text-xl font-black text-white font-headline mb-4">sqlcx</div>
        <p class="text-muted text-sm max-w-xs leading-relaxed">SQL-first code generation for the modern developer. Build fast, stay lean.</p>
      </div>

      <!-- Product links -->
      <div class="flex flex-col gap-3">
        <h5 class="font-label text-[10px] uppercase tracking-[0.2em] text-white">Product</h5>
        <a class="text-muted hover:text-lime text-xs transition-all font-label uppercase no-underline" href="/getting-started/quick-start/">Documentation</a>
        <a class="text-muted hover:text-lime text-xs transition-all font-label uppercase no-underline" href="https://github.com/JagritGumber/sqlcx" target="_blank" rel="noopener">GitHub</a>
        <a class="text-muted hover:text-lime text-xs transition-all font-label uppercase no-underline" href="/comparison">Comparison</a>
      </div>

      <!-- Languages -->
      <div class="flex flex-col gap-3">
        <h5 class="font-label text-[10px] uppercase tracking-[0.2em] text-white">Languages</h5>
        <a class="text-muted hover:text-lime text-xs transition-all font-label uppercase no-underline" href="/typescript/typebox">TypeScript</a>
        <a class="text-muted hover:text-lime text-xs transition-all font-label uppercase no-underline" href="/go/structs">Go</a>
        <a class="text-muted hover:text-lime text-xs transition-all font-label uppercase no-underline" href="/rust/serde">Rust</a>
      </div>

      <!-- Databases -->
      <div class="flex flex-col gap-3">
        <h5 class="font-label text-[10px] uppercase tracking-[0.2em] text-white">Databases</h5>
        <a class="text-muted hover:text-lime text-xs transition-all font-label uppercase no-underline" href="/databases/postgresql">PostgreSQL</a>
        <a class="text-muted hover:text-lime text-xs transition-all font-label uppercase no-underline" href="/databases/mysql">MySQL</a>
        <a class="text-muted hover:text-lime text-xs transition-all font-label uppercase no-underline" href="/databases/sqlite">SQLite</a>
      </div>
    </div>

    <div class="flex flex-col md:flex-row justify-between items-center gap-4 pt-6 border-t border-white/5">
      <p class="font-label text-xs uppercase tracking-widest text-muted">© 2025 sqlcx. SQL is the source of truth.</p>
    </div>
  </div>
</footer>
