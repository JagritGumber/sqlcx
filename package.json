{
  "name": "sqlcx",
  "version": "0.1.0",
  "description": "SQL-first cross-language type-safe code generator",
  "type": "module",
  "bin": {
    "sqlcx": "src/cli/index.ts"
  },
  "exports": {
    ".": "./src/index.ts",
    "./config": "./src/config/index.ts",
    "./parser/postgres": "./src/parser/postgres.ts",
    "./generator/typescript": "./src/generator/typescript/index.ts",
    "./generator/typescript/schema/typebox": "./src/generator/typescript/schema/typebox.ts",
    "./generator/typescript/driver/bun-sql": "./src/generator/typescript/driver/bun-sql.ts"
  },
  "scripts": {
    "test": "bun test",
    "generate": "bun run src/cli/index.ts generate",
    "check": "bun run src/cli/index.ts check"
  },
  "keywords": ["sql", "codegen", "typescript", "typebox", "orm", "type-safe"],
  "license": "MIT",
  "dependencies": {
    "node-sql-parser": "^5.4.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "typescript": "^5.9.3"
  }
}
